# NM-GPT Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (required for embeddings & generation)
GOOGLE_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed CORS origins (defaults to localhost:3000,3001)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# LLM request timeout in seconds (default: 60)
LLM_TIMEOUT_SECONDS=60
